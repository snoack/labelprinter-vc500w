#!/usr/bin/make -f

export PYBUILD_NAME = labelprinter
COMPLETION_DIR = debian/build/completion

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	dh_auto_build
	mkdir -p $(COMPLETION_DIR)/bash $(COMPLETION_DIR)/fish $(COMPLETION_DIR)/zsh
	register-python-argcomplete --shell bash --no-defaults bclprinter \
		> $(COMPLETION_DIR)/bash/bclprinter
	register-python-argcomplete --shell fish bclprinter \
		> $(COMPLETION_DIR)/fish/bclprinter.fish
	register-python-argcomplete --shell zsh bclprinter \
		> $(COMPLETION_DIR)/zsh/_bclprinter

override_dh_auto_test:
	python3 -m unittest discover -s labelprinter/test -p test_printer.py

override_dh_python3:
	dh_python3 --no-guessing-deps
